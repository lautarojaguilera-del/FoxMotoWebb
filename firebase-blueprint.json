{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A motorcycle part or accessory",
      "type": "object",
      "properties": {
        "sku": { "type": "string", "description": "Unique identifier (SKU)" },
        "title": { "type": "string", "description": "Name of the product" },
        "price": { "type": "string", "description": "Price string (e.g. $1.234,56)" },
        "stock": { "type": "string", "description": "Stock status string" },
        "img": { "type": "string", "description": "URL to the product image" },
        "last_updated": { "type": "string", "format": "date-time", "description": "When the product was last scraped" }
      },
      "required": ["sku", "title", "price"]
    },
    "ScrapeStatus": {
      "title": "ScrapeStatus",
      "description": "Current status of the scraping process",
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["idle", "scraping", "error"] },
        "current_page": { "type": "number" },
        "total_products": { "type": "number" },
        "last_run": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of all scraped products"
    },
    "/status/current": {
      "schema": "ScrapeStatus",
      "description": "Current scraping status"
    }
  }
}
